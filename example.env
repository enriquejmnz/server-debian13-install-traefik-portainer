# === Configuración para instalación no interactiva ===
# Copiar a .env y ajustar valores según el servidor.
# Usar con: sudo bash main.sh --non-interactive --step all
# O:       sudo bash main.sh --non-interactive --step secure
# O:       sudo bash main.sh --env-file ./example.env

# === Hardening: SSH ===
SSH_PORT=22
# "s" para deshabilitar autenticación por contraseña, "n" para mantenerla
DISABLE_PASSWORD_AUTH=s
ADMIN_USER=admin
# Dejar vacío para omitir (configurar manualmente vía ssh-copy-id)
# ADMIN_SSH_KEY="ssh-ed25519 AAAA..."

# === Docker ===
# Dejar vacío para omitir
DOCKER_USER=admin

# === Traefik + Portainer ===
BASE_DOMAIN=example.com
TRAEFIK_SUBDOMAIN=traefik
PORTAINER_SUBDOMAIN=portainer
EMAIL_ADMIN=admin@example.com
TRAEFIK_USER=admin
TRAEFIK_PASSWORD=changeme

# === Restore / Migración de dominio (solo --step restore) ===
# BACKUP_FILE=/tmp/traefik-portainer-backup-YYYYMMDD_HHMMSS.tar.gz
# NEW_BASE_DOMAIN=nuevodominio.com
# NEW_TRAEFIK_SUBDOMAIN=traefik
# NEW_PORTAINER_SUBDOMAIN=portainer
# NEW_LETSENCRYPT_EMAIL=admin@nuevodominio.com
# FORCE_NEW_ACME=true   # renombra acme.json para forzar nuevos certificados

# === Misc ===
# TIMEZONE=America/Argentina/Buenos_Aires
